<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Effito Favicon</title>
    <style>
        body {
            margin: 0;
            padding: 20px;
            background: #f0f0f0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            font-family: serif;
        }
        .container {
            text-align: center;
        }
        canvas {
            border: 1px solid #ccc;
            image-rendering: crisp-edges;
        }
        button {
            margin-top: 20px;
            padding: 10px 20px;
            background: #1a1a2e;
            color: white;
            border: none;
            cursor: pointer;
            font-size: 16px;
        }
        button:hover {
            background: #2a2a3e;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2>Effito Favicon (64x64)</h2>
        <canvas id="favicon" width="64" height="64"></canvas>
        <br>
        <button onclick="downloadFavicon()">Download favicon.png</button>
    </div>

    <script>
        const canvas = document.getElementById('favicon');
        const ctx = canvas.getContext('2d');

        // Background color (beige from the original)
        const bgColor = '#F5F0E8';
        const textColor = '#1C2541'; // Dark navy blue

        // Draw rounded rectangle background
        function drawRoundedRect(x, y, width, height, radius) {
            ctx.beginPath();
            ctx.moveTo(x + radius, y);
            ctx.lineTo(x + width - radius, y);
            ctx.quadraticCurveTo(x + width, y, x + width, y + radius);
            ctx.lineTo(x + width, y + height - radius);
            ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height);
            ctx.lineTo(x + radius, y + height);
            ctx.quadraticCurveTo(x, y + height, x, y + height - radius);
            ctx.lineTo(x, y + radius);
            ctx.quadraticCurveTo(x, y, x + radius, y);
            ctx.closePath();
            ctx.fill();
        }

        // Draw background
        ctx.fillStyle = bgColor;
        drawRoundedRect(0, 0, 64, 64, 8);

        // Draw letter "E"
        ctx.fillStyle = textColor;
        ctx.font = 'bold 48px serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('E', 32, 34);

        function downloadFavicon() {
            canvas.toBlob(function(blob) {
                const url = URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.download = 'favicon.png';
                link.href = url;
                link.click();
                URL.revokeObjectURL(url);
            });
        }
    </script>
</body>
</html>
